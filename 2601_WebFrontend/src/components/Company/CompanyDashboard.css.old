:root {
    --nav-bg: var(--bg-dark, #0a0a0a);
    --card-bg: var(--bg-card, #121212);
    --border-color: #2d3748;
    --text-white: var(--text-primary, #ffffff);
    --text-gray: var(--text-muted, #9ca3af);
    --hover-bg: rgba(255, 255, 255, 0.05);
    
    --accent-green: var(--primary, #10b981);
    --accent-green-light: rgba(16, 185, 129, 0.15);
    --accent-green-hover: var(--primary-dark, #059669);
}

.company-dashboard-container {
    background-color: var(--bg-darker, #050505);
    min-height: 100vh;
    color: var(--text-white);
}

/* Navbar */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    height: 72px;
    background-color: var(--nav-bg);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
}

.nav-left {
    display: flex;
    align-items: center;
    gap: 48px;
}

.logo-section {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
    font-size: 18px;
    cursor: pointer;
    color: var(--text-white);
}

.nav-links {
    display: flex;
    gap: 8px;
}

.nav-link {
    color: var(--text-gray);
    text-decoration: none;
    font-size: 14px;
    padding: 8px 12px;
    border-radius: 6px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-weight: 500;
}

.nav-link:hover {
    color: var(--text-white);
    background-color: var(--hover-bg);
}

.nav-link.active {
    background-color: var(--accent-green-light);
    color: var(--accent-green);
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
}

.user-profile {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 8px;
    transition: background-color 0.2s;
}

.user-profile:hover {
    background-color: var(--hover-bg);
}

.avatar {
    width: 36px;
    height: 36px;
    background-color: var(--accent-green-light);
    color: var(--accent-green);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    flex-shrink: 0;
}

.user-info {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
}

.user-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-white);
}

.user-role {
    font-size: 12px;
    color: var(--text-gray);
}

.notification-btn {
    background: none;
    border: none;
    color: var(--text-gray);
    cursor: pointer;
    position: relative;
    padding: 8px;
    border-radius: 50%;
    transition: all 0.2s;
}

.notification-btn:hover {
    color: var(--text-white);
    background-color: var(--hover-bg);
}

.notification-dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 8px;
    height: 8px;
    background-color: var(--accent-green);
    border-radius: 50%;
    border: 2px solid var(--nav-bg);
}

/* Main Content */
.main-content {
    padding: 32px 48px;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
}

.header-title h1 {
    font-size: 24px;
    margin: 0 0 6px 0;
    font-weight: 600;
    color: var(--text-white);
}

.header-title p {
    color: var(--text-gray);
    font-size: 14px;
    margin: 0;
}

.btn-primary {
    background-color: var(--accent-green);
    color: #000;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
}

.btn-primary:hover {
    background-color: var(--accent-green-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-bottom: 40px;
}

.stat-card {
    background-color: var(--card-bg);
    padding: 24px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all 0.2s ease;
    height: 100px; /* Enforcing a compact height */
}

.stat-card:hover {
    border-color: #3f4246;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
}

.stat-icon {
    width: 48px;
    height: 48px;
    background-color: rgba(255, 255, 255, 0.03);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-green);
}

.stat-info .label {
    color: var(--text-gray);
    font-size: 13px;
    margin-bottom: 2px;
    font-weight: 500;
}

.stat-info .value {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-white);
    margin: 0;
}

/* Search Bar */
.filter-section {
    margin-bottom: 12px;
}

.search-bar {
    position: relative;
    max-width: 300px;
}

.search-bar input {
    width: 100%;
    padding: 10px 16px;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-white);
    font-size: 14px;
    transition: all 0.2s;
}

.search-bar input:focus {
    outline: none;
    border-color: var(--accent-green);
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.1);
}

/* Modal */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.75);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
}

.modal-content {
    background-color: var(--card-bg);
    border-radius: 16px;
    padding: 32px;
    width: 100%;
    max-width: 500px;
    border: 1px solid var(--border-color);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    color: var(--text-white);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.modal-header h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-white);
    margin: 0;
}

.close-btn {
    background: none;
    border: none;
    color: var(--text-gray);
    font-size: 24px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
}

.close-btn:hover {
    color: var(--text-white);
}

.upload-area {
    border: 2px dashed var(--border-color);
    border-radius: 12px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background-color: rgba(255, 255, 255, 0.01);
}

.upload-area:hover {
    border-color: var(--accent-green);
    background-color: rgba(16, 185, 129, 0.02);
}
